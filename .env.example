# =============================================================
# Digital Legacy and Emergency Access Vault — Environment Variables
# Copy this file to .env.local and fill in all values
# =============================================================

# ── NextAuth
NEXTAUTH_SECRET=your-super-secret-nextauth-key-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ── MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/digital-legacy-vault?retryWrites=true&w=majority

# ── Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Encryption Key (32 bytes = 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-encryption-key

# ── Polygon Amoy Testnet (Blockchain)
# Get RPC URL from: https://dashboard.alchemy.com/
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your-api-key
# Wallet private key for contract interactions (no leading 0x)
DEPLOYER_PRIVATE_KEY=your-wallet-private-key
# Contract address after deploying DocumentRegistry.sol
CONTRACT_ADDRESS=0x...

# ── Resend Email
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com

# ── Vercel Cron Secret (any random string)
CRON_SECRET=your-random-cron-secret

# ── App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
